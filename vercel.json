{
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": false,
  "routes": [
    {
      "src": "/zeta.jar",
      "headers": {
        "cache-control": "no-store, no-cache, must-revalidate, proxy-revalidate, max-age=0"
      },
      "dest": "/web/zeta.jar"
    },
    {
      "src": "/(.*)",
      "dest": "/web/$1"
    }
  ]
}
